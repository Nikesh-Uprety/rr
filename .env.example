DATABASE_URL=postgresql://devuser:devpass@localhost:5432/devdb
SESSION_SECRET=some-long-random-string-at-least-32-chars
NODE_ENV=development
PORT=5001

# Email (Resend - Better than Gmail for production)
# Get API key from https://resend.com/dashboard/api-keys
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=Your App Name

# Legacy Mailjet (for development only)
# Get credentials from https://app.mailjet.com/
SMTP_HOST=in-v3.mailjet.com
SMTP_PORT=587
SMTP_USER=your-mailjet-api-key
SMTP_PASS=your-mailjet-secret-key

# 2FA
OTP_EXPIRY_MINUTES=10

# Uploads persistence
# For local development, you can leave this unset (defaults to `./uploads`).
# On Railway, mount a persistent volume to the container path and set `UPLOADS_DIR`
# to that same path (recommended: `/uploads`).
UPLOADS_DIR=/uploads

# S3-Compatible Storage (Tigris Storage)
# Configure for Railway deployment
S3_ENDPOINT=https://t3.storage.dev
S3_REGION=auto
S3_BUCKET=expandable-cube-xogsjgx1g
S3_ACCESS_KEY_ID=tid_dXDjuETPLqTrwnHNIAFmBoZNBs_akGLrQvHsTRmqVHsaTeCSNd
S3_SECRET_ACCESS_KEY=tsec_1ir5o9rSoDN5V+eGLpFASk8GA6YV-2mztVQcyYN-sER2NsYF1sX3Cl_9hSTu_fiiShc3HK

# Alternative: Tigris Storage (your new bucket)
# TIGRIS_ENDPOINT=https://t3.storage.dev
# TIGRIS_REGION=auto
# TIGRIS_BUCKET=your-tigris-bucket-name
# TIGRIS_ACCESS_KEY_ID=tid_dXDjuETPLqTrwnHNIAFmBoZNBs_akGLrQvHsTRmqVHsaTeCSNd
# TIGRIS_SECRET_ACCESS_KEY=tsec_1ir5o9rSoDN5V+eGLpFASk8GA6YV-2mztVQcyYN-sER2NsYF1sX3Cl_9hSTu_fiiShc3HK

